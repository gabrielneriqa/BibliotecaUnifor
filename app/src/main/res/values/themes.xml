<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="chip">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:background">#DDDDDD</item>
        <item name="android:padding">8dp</item>
        <item name="android:layout_marginEnd">6dp</item>
    </style>

    <style name="Theme.UniforEventos" parent="Theme.AppCompat.DayNight.NoActionBar" />

    <style name="RoundedBookCover">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">8dp</item>
    </style>

    <style name="RoundedBookCoverLarge">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">16dp</item>
    </style>

    <style name="RoundedAvatarSmall">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">999dp</item>
    </style>
    <style name="CalendarWeekDay">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">28dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#4A4A4A</item>
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="CalendarDay">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#4A4A4A</item>
        <item name="android:textSize">12sp</item>
    </style>

    <style name="CalendarDayEmpty">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_columnWeight">1</item>
    </style>

    <style name="CalendarDaySelectedBlue">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">12sp</item>
        <item name="android:background">@drawable/bg_calendar_day_blue</item>
    </style>

    <style name="CalendarDaySelectedRed">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_columnWeight">1</item>
        <item name="android:gravity">center</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">12sp</item>
        <item name="android:background">@drawable/bg_calendar_day_red</item>
    </style>
</resources>