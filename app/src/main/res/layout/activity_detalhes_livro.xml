<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- CONTEÚDO PRINCIPAL -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

        <!-- HEADER AZUL -->
        <LinearLayout
            android:id="@+id/headerTop"
            android:layout_width="match_parent"
            android:layout_height="304dp"
            android:background="@drawable/bg_header"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp">

            <!-- TOPO / STATUS -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="32dp">

                <TextView
                    android:id="@+id/tvHora"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="9:41"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="12dp"
                        android:contentDescription="Sinal"
                        android:src="@drawable/ic_status_signal"
                        android:tint="#FFFFFF" />

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="Wi-Fi"
                        android:src="@drawable/ic_status_wifi"
                        android:tint="#FFFFFF" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="Bateria"
                        android:src="@drawable/ic_status_battery"
                        android:tint="#FFFFFF" />
                </LinearLayout>
            </RelativeLayout>

            <!-- TÍTULO COM VOLTAR -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnVoltar"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:contentDescription="Voltar"
                    android:src="@drawable/ic_arrow_back"
                    android:tint="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:text="Detalhes do livro"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp" />
            </LinearLayout>

            <!-- CAPA CENTRAL -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgLivro"
                android:layout_width="150dp"
                android:layout_height="205dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:contentDescription="Capa do livro"
                android:scaleType="centerCrop"
                android:src="@drawable/mysql"
                app:shapeAppearanceOverlay="@style/RoundedBookCoverLarge" />

        </LinearLayout>

        <!-- ÁREA BRANCA / CONTEÚDO -->
        <ScrollView
            android:id="@+id/scrollContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/headerTop"
            android:layout_above="@id/bottomNav"
            android:background="#FFFFFF"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="26dp"
                android:paddingTop="14dp"
                android:paddingEnd="26dp"
                android:paddingBottom="32dp">

                <!-- NOME DO LIVRO -->
                <TextView
                    android:id="@+id/tvTituloLivro"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sistemas de Banco de Dados"
                    android:textColor="#1D1B34"
                    android:textSize="26sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSubInfo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Código: 023B23 | Categoria: Tecnologia da informação"
                    android:textColor="#6B6B7A"
                    android:textSize="11sp" />

                <!-- PROFESSORA -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="22dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <com.google.android.material.imageview.ShapeableImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:contentDescription="Professora"
                        android:scaleType="centerCrop"
                        android:src="@drawable/foto_notificacao"
                        app:shapeAppearanceOverlay="@style/RoundedAvatarSmall" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Professora Ana"
                            android:textColor="#1D1B34"
                            android:textSize="17sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Autor"
                            android:textColor="#8B86A0"
                            android:textSize="15sp" />
                    </LinearLayout>

                </LinearLayout>

                <!-- CHIPS -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="94dp"
                        android:layout_height="24dp"
                        android:background="@drawable/bg_chip_disponivel"
                        android:gravity="center"
                        android:text="DISPONÍVEL"
                        android:textAllCaps="true"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="94dp"
                        android:layout_height="24dp"
                        android:layout_marginStart="8dp"
                        android:background="@drawable/bg_chip_disponivel"
                        android:gravity="center"
                        android:text="4 CÓPIAS"
                        android:textAllCaps="true"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- SOBRE -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="Sobre o livro"
                    android:textColor="#1D1B34"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="14dp"
                    android:lineSpacingExtra="4dp"
                    android:text="Sistemas de banco de dados apresenta de forma profunda e atualizada os aspectos mais importantes dos sistemas e aplicações de banco de dados, bem como das tecnologias relacionadas. Esta obra de referência introduz os conceitos fundamentais necessários para projetar, usar e implementar sistemas de banco de dados, enfatizando fundamentos de modelagem, projeto, linguagens e modelos fornecidos pelos sistemas de gerenciamento e técnicas de implementação."
                    android:textColor="#9B98AF"
                    android:textSize="16sp" />

                <!-- BOTÃO -->
                <LinearLayout
                    android:id="@+id/btnReservar"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginTop="26dp"
                    android:background="@drawable/bg_button_reservar"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingStart="24dp"
                    android:paddingEnd="16dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="RESERAR"
                        android:textAllCaps="true"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="34dp"
                        android:layout_height="34dp"
                        android:background="@drawable/bg_circle_arrow"
                        android:gravity="center"
                        android:text="→"
                        android:textColor="#FFFFFF"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- MENU INFERIOR -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/bg_gradient"
            app:itemIconTint="@color/nav_item_color"
            app:itemTextColor="@color/nav_item_color"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu" />

    </RelativeLayout>

    <!-- SIDEBAR PRONTA -->
    <LinearLayout
        android:id="@+id/sidebarMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu"
            android:textColor="#2B2B2B"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Início"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Meus livros"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Reservas"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Perfil"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>