<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="10dp"
    android:layout_marginBottom="10dp"
    android:background="#FFFFFF">

    <!-- CAPA -->
    <ImageView
        android:id="@+id/imgCapaLivro"
        android:layout_width="60dp"
        android:layout_height="80dp"
        android:background="#D9D9D9"
        android:contentDescription="Capa"/>

    <!-- TEXTO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_weight="1"
        android:layout_marginStart="10dp">

        <TextView
            android:id="@+id/tvTituloLivro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título do Livro"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/tvAutorLivro"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Autor: Nome do autor"
            android:textSize="12sp"
            android:textColor="#666"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ver detalhes"
            android:textSize="12sp"
            android:textColor="#5A5AFF"/>

    </LinearLayout>

    <TextView
        android:id="@+id/tvDisponibilidade"
        android:layout_width="90dp"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_available_button"
        android:gravity="center"
        android:text="Disponível"
        android:textColor="#28D888"
        android:textSize="13sp" />

</LinearLayout>

