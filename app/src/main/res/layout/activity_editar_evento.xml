<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F6">

    <FrameLayout
        android:id="@+id/topImageContainer"
        android:layout_width="0dp"
        android:layout_height="225dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/ivImagemEvento"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:contentDescription="Imagem do evento"
            android:scaleType="centerCrop"
            tools:src="@drawable/img_evento_placeholder" />

        <View
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="#33000000" />
    </FrameLayout>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/ivVoltar"
        android:layout_width="22dp"
        android:layout_height="22dp"
        android:layout_marginStart="18dp"
        android:layout_marginTop="44dp"
        android:contentDescription="Voltar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@android:drawable/ic_media_previous"
        app:tint="#FFFFFF" />

    <TextView
        android:id="@+id/tvTituloTela"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:fontFamily="@font/poppins_regular"
        android:text="Editar evento"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        app:layout_constraintBottom_toBottomOf="@id/ivVoltar"
        app:layout_constraintStart_toEndOf="@id/ivVoltar"
        app:layout_constraintTop_toTopOf="@id/ivVoltar" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardSalvar"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginTop="42dp"
        android:layout_marginEnd="16dp"
        app:cardBackgroundColor="#D9DDFE"
        app:cardCornerRadius="8dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:layout_gravity="center"
            android:contentDescription="Salvar"
            app:srcCompat="@android:drawable/ic_menu_save"
            app:tint="#FF7F87" />
    </com.google.android.material.card.MaterialCardView>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/scrollContent"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topImageContainer">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="16dp"
            android:paddingEnd="22dp"
            android:paddingBottom="24dp">

            <TextView
                android:id="@+id/tvSecaoDados"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_bold"
                android:text="Dados do evento"
                android:textColor="#1F1F2E"
                android:textSize="18sp" />

            <EditText
                android:id="@+id/etTituloEvento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@android:color/transparent"
                android:fontFamily="@font/poppins_bold"
                android:hint="Título do evento"
                android:inputType="textCapSentences"
                android:paddingTop="8dp"
                android:paddingBottom="10dp"
                android:text=""
                android:textColor="#1F1F2E"
                android:textColorHint="#8B8FA8"
                android:textSize="18sp"
                tools:text="Inovação: futuro com IA" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#DADBE5" />

            <TextView
                android:id="@+id/tvSecaoDataHora"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Data e horário"
                android:textColor="#1F1F2E"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/layoutDataHora"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardBackgroundColor="#E7EAFF"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:contentDescription="Data"
                        app:srcCompat="@android:drawable/ic_menu_my_calendar"
                        app:tint="#5966FF" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/etDataEvento"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Data do evento"
                        android:inputType="date"
                        android:padding="0dp"
                        android:text=""
                        android:textColor="#3D3D53"
                        android:textColorHint="#8B8FA8"
                        android:textSize="15sp"
                        tools:text="10 de Abril, 2026" />

                    <EditText
                        android:id="@+id/etHorarioEvento"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Horário"
                        android:inputType="text"
                        android:padding="0dp"
                        android:text=""
                        android:textColor="#8B8FA8"
                        android:textColorHint="#B0B0BB"
                        android:textSize="13sp"
                        tools:text="Sexta-feira, 16h - 17h" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="#DADBE5" />

            <TextView
                android:id="@+id/tvSecaoLocal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Local"
                android:textColor="#1F1F2E"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/layoutLocal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.card.MaterialCardView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    app:cardBackgroundColor="#E7EAFF"
                    app:cardCornerRadius="10dp"
                    app:cardElevation="0dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:layout_gravity="center"
                        android:contentDescription="Local"
                        app:srcCompat="@android:drawable/ic_menu_mylocation"
                        app:tint="#5966FF" />
                </com.google.android.material.card.MaterialCardView>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/etLocalEvento"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Nome do local"
                        android:inputType="textCapSentences"
                        android:padding="0dp"
                        android:text=""
                        android:textColor="#2E2E40"
                        android:textColorHint="#8B8FA8"
                        android:textSize="15sp"
                        tools:text="Teatro Celina Queiroz" />

                    <EditText
                        android:id="@+id/etEnderecoEvento"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Endereço"
                        android:inputType="textCapSentences"
                        android:padding="0dp"
                        android:text=""
                        android:textColor="#8B8FA8"
                        android:textColorHint="#B0B0BB"
                        android:textSize="13sp"
                        tools:text="Av. Washington Soares, 1321" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="#DADBE5" />

            <TextView
                android:id="@+id/tvSecaoOrganizador"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Organizador"
                android:textColor="#1F1F2E"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/layoutOrganizador"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivOrganizador"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:contentDescription="Organizador"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/img_avatar_1" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <EditText
                        android:id="@+id/etNomeOrganizador"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Nome do organizador"
                        android:inputType="textCapWords"
                        android:padding="0dp"
                        android:text=""
                        android:textColor="#2E2E40"
                        android:textColorHint="#8B8FA8"
                        android:textSize="15sp"
                        tools:text="Professora Ana" />

                    <EditText
                        android:id="@+id/etCargoOrganizador"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Cargo"
                        android:inputType="textCapWords"
                        android:padding="0dp"
                        android:text=""
                        android:textColor="#8B8FA8"
                        android:textColorHint="#B0B0BB"
                        android:textSize="13sp"
                        tools:text="Organizador" />
                </LinearLayout>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="12dp"
                android:background="#DADBE5" />

            <TextView
                android:id="@+id/tvSecaoDescricao"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Sobre o evento"
                android:textColor="#1F1F2E"
                android:textSize="16sp" />

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardDescricao"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="12dp"
                app:cardBackgroundColor="#F4F4F6"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp"
                app:strokeColor="#DADBE5"
                app:strokeWidth="1dp">

                <EditText
                    android:id="@+id/etDescricaoEvento"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="top|start"
                    android:hint="Descrição do evento"
                    android:inputType="textMultiLine|textCapSentences"
                    android:padding="14dp"
                    android:text=""
                    android:textColor="#2E2E40"
                    android:textColorHint="#8B8FA8"
                    android:textSize="14sp"
                    tools:text="Prepare-se para uma experiência inspiradora sobre como a Inteligência Artificial está moldando o futuro." />
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSalvarAlteracoes"
                android:layout_width="220dp"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_bold"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:letterSpacing="0.08"
                android:text="SALVAR ALTERAÇÕES"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                app:backgroundTint="#72D3A4"
                app:cornerRadius="14dp"
                app:icon="@android:drawable/ic_media_next"
                app:iconGravity="textEnd"
                app:iconPadding="8dp"
                app:iconTint="#FFFFFF"
                app:rippleColor="#33FFFFFF" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:background="#5966FF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Notificações"
                android:src="@android:drawable/ic_menu_view"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical"
            android:background="#80FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Notificações"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical"
            android:background="#80FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Calendário"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical"
            android:background="#80FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Perfil"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>