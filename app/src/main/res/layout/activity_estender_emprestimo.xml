<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- ═══════════════════════════════════════
         CONTEÚDO PRINCIPAL
    ════════════════════════════════════════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- HEADER AZUL -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="#4A5BEF"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="12dp">

            <ImageView
                android:id="@+id/ivVoltar"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="#FFFFFF" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:fontFamily="@font/poppins_bold"
                android:text="Detalhes do livro"
                android:textColor="#FFFFFF"
                android:textSize="17sp" />

            <ImageView
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:padding="10dp"
                android:src="@drawable/ic_bookmark_outline"
                android:tint="#FFFFFF" />

        </LinearLayout>

        <!-- SCROLL PRINCIPAL -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="never">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- ÁREA AZUL COM CAPA DO LIVRO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="190dp"
                    android:background="#4A5BEF"
                    android:gravity="center">

                    <ImageView
                        android:layout_width="115dp"
                        android:layout_height="160dp"
                        android:scaleType="fitCenter"
                        android:src="@drawable/livro_mock" />

                </LinearLayout>

                <!-- ÁREA BRANCA COM CONTEÚDO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="#FFFFFF"
                    android:orientation="vertical"
                    android:paddingStart="20dp"
                    android:paddingEnd="20dp"
                    android:paddingTop="20dp"
                    android:paddingBottom="28dp">

                    <!-- Título do livro -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Harry potter"
                        android:textColor="#1A1A1A"
                        android:textSize="21sp" />

                    <!-- Código e categoria -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/poppins_regular"
                        android:text="Código: TEC-10327 | Categoria: Fantasia"
                        android:textColor="#888888"
                        android:textSize="11sp" />

                    <!-- Linha do autor -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:layout_width="44dp"
                            android:layout_height="44dp"
                            android:background="@drawable/bg_round_avatar"
                            android:clipToOutline="true"
                            android:scaleType="centerCrop"
                            android:src="@drawable/autor" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="10dp"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_bold"
                                android:text="Professora Ana"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_regular"
                                android:text="Autor"
                                android:textColor="#888888"
                                android:textSize="12sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Label "Estender até:" -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:fontFamily="@font/poppins_bold"
                        android:text="Estender até:"
                        android:textColor="#1A1A1A"
                        android:textSize="15sp" />

                    <!-- CARD DO CALENDÁRIO -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_calendar_card"
                        android:elevation="3dp"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <!-- Cabeçalho: mês + setas -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:gravity="center_vertical"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tvMesAno"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:fontFamily="@font/poppins_bold"
                                android:text="Abril 2026"
                                android:textColor="#1A1A1A"
                                android:textSize="14sp" />

                            <ImageView
                                android:id="@+id/btnMesAnterior"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:padding="5dp"
                                android:src="@drawable/ic_arrow_back"
                                android:tint="#666666" />

                            <ImageView
                                android:id="@+id/btnProximoMes"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:padding="5dp"
                                android:rotation="180"
                                android:src="@drawable/ic_arrow_back"
                                android:tint="#666666" />

                        </LinearLayout>

                        <!-- Cabeçalho dos dias da semana (D S T Q Q S S) -->
                        <GridLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:columnCount="7">

                            <TextView style="@style/CalendarWeekDay" android:text="D" />
                            <TextView style="@style/CalendarWeekDay" android:text="S" />
                            <TextView style="@style/CalendarWeekDay" android:text="T" />
                            <TextView style="@style/CalendarWeekDay" android:text="Q" />
                            <TextView style="@style/CalendarWeekDay" android:text="Q" />
                            <TextView style="@style/CalendarWeekDay" android:text="S" />
                            <TextView style="@style/CalendarWeekDay" android:text="S" />

                        </GridLayout>

                        <!-- Grade de dias (alimentada pelo CalendarAdapter) -->
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/recyclerCalendar"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:nestedScrollingEnabled="false" />

                    </LinearLayout>

                    <!-- Legenda: Reservado -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="10dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="10dp"
                            android:layout_height="10dp"
                            android:background="@drawable/bg_calendar_day_red" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="6dp"
                            android:fontFamily="@font/poppins_regular"
                            android:text="Reservado"
                            android:textColor="#888888"
                            android:textSize="12sp" />

                    </LinearLayout>

                    <!-- BOTÃO CONFIRMAR -->
                    <LinearLayout
                        android:id="@+id/btnConfirmar"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginTop="20dp"
                        android:background="@drawable/bg_confirm_button"
                        android:gravity="center"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/poppins_bold"
                            android:letterSpacing="0.08"
                            android:text="CONFIRMAR"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp" />

                        <ImageView
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:layout_marginStart="10dp"
                            android:rotation="180"
                            android:src="@drawable/ic_arrow_back"
                            android:tint="#FFFFFF" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </ScrollView>

        <!-- BOTTOM NAVIGATION -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:background="#FFFFFF"
            app:itemIconTint="@color/nav_item_color"
            app:itemTextColor="@color/nav_item_color"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu" />

    </LinearLayout>

    <!-- ═══════════════════════════════════════
         OVERLAY DE SUCESSO (invisível até CONFIRMAR)
    ════════════════════════════════════════════ -->
    <FrameLayout
        android:id="@+id/successOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F5F5F5"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="32dp">

            <ImageView
                android:id="@+id/imgSuccess"
                android:layout_width="160dp"
                android:layout_height="160dp"
                android:background="@drawable/bg_success_circle"
                android:padding="32dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_success_check" />

            <TextView
                android:id="@+id/tvSuccessLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Reserva confirmada"
                android:textColor="#222222"
                android:textSize="20sp" />

        </LinearLayout>

    </FrameLayout>

</FrameLayout>