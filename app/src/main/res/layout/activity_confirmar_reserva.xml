<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- CONTEÚDO PRINCIPAL -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

        <!-- HEADER AZUL -->
        <LinearLayout
            android:id="@+id/headerTop"
            android:layout_width="match_parent"
            android:layout_height="304dp"
            android:background="@drawable/bg_header"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="16dp"
            android:paddingEnd="24dp">

            <!-- STATUS BAR -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="32dp">

                <TextView
                    android:id="@+id/tvHora"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:text="9:41"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="12dp"
                        android:contentDescription="Sinal"
                        android:src="@drawable/ic_status_signal"
                        android:tint="#FFFFFF" />

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="Wi-Fi"
                        android:src="@drawable/ic_status_wifi"
                        android:tint="#FFFFFF" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="Bateria"
                        android:src="@drawable/ic_status_battery"
                        android:tint="#FFFFFF" />

                </LinearLayout>

            </RelativeLayout>

            <!-- TÍTULO + FAVORITO -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp">

                <LinearLayout
                    android:id="@+id/backTitleContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/btnVoltar"
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="Voltar"
                        android:src="@drawable/ic_arrow_back"
                        android:tint="#FFFFFF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:text="Detalhes do livro"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp" />

                </LinearLayout>

                <FrameLayout
                    android:id="@+id/btnFavorito"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/bg_bookmark_button">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_gravity="center"
                        android:contentDescription="Favoritar"
                        android:src="@drawable/ic_bookmark_outline"
                        android:tint="#FA7272" />

                </FrameLayout>

            </RelativeLayout>

            <!-- CAPA CENTRAL -->
            <com.google.android.material.imageview.ShapeableImageView
                android:id="@+id/imgLivro"
                android:layout_width="150dp"
                android:layout_height="205dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="10dp"
                android:contentDescription="Capa do livro"
                android:scaleType="centerCrop"
                android:src="@drawable/mysql"
                app:shapeAppearanceOverlay="@style/RoundedBookCoverLarge" />

        </LinearLayout>

        <!-- CONTEÚDO FIXO ENTRE HEADER E MENU -->
        <LinearLayout
            android:id="@+id/contentContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/headerTop"
            android:layout_above="@id/bottomNav"
            android:background="#FFFFFF"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="14dp"
            android:paddingEnd="24dp"
            android:paddingBottom="20dp">

            <!-- TÍTULO DO LIVRO ALINHADO À ESQUERDA -->
            <TextView
                android:id="@+id/tvTituloLivro"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="start"
                android:text="Sistemas de Banco de Dados"
                android:textAlignment="viewStart"
                android:textColor="#1D1B34"
                android:textSize="25sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvSubInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="start"
                android:text="Código: 023B23 | Categoria: Tecnologia da informação"
                android:textAlignment="viewStart"
                android:textColor="#6B6B7A"
                android:textSize="11sp" />

            <!-- AUTORA / PROFESSORA ALINHADA À ESQUERDA -->
            <LinearLayout
                android:id="@+id/authorContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <com.google.android.material.imageview.ShapeableImageView
                    android:layout_width="50dp"
                    android:layout_height="50dp"
                    android:contentDescription="Professora"
                    android:scaleType="centerCrop"
                    android:src="@drawable/autor"
                    app:shapeAppearanceOverlay="@style/RoundedAvatarSmall" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Professora Ana"
                        android:textColor="#1D1B34"
                        android:textSize="17sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="3dp"
                        android:text="Autor"
                        android:textColor="#8B86A0"
                        android:textSize="15sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- ESPAÇO FLEXÍVEL PARA EMPURRAR A CONFIRMAÇÃO -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <!-- PERGUNTA CENTRALIZADA -->
            <TextView
                android:id="@+id/tvPergunta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:text="Deseja confirmar sua reserva"
                android:textAlignment="center"
                android:textColor="#3D3951"
                android:textSize="19sp" />

            <!-- BOTÕES -->
            <LinearLayout
                android:id="@+id/buttonsContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="44dp"
                android:gravity="center"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/btnCancelar"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_cancelar"
                    android:gravity="center"
                    android:text="Cancelar"
                    android:textColor="#2F5AB7"
                    android:textSize="16sp"
                    android:textStyle="bold" />

                <Space
                    android:layout_width="20dp"
                    android:layout_height="1dp" />

                <TextView
                    android:id="@+id/btnSim"
                    android:layout_width="0dp"
                    android:layout_height="58dp"
                    android:layout_weight="1"
                    android:background="@drawable/bg_button_sim"
                    android:gravity="center"
                    android:text="Sim"
                    android:textColor="#FFFFFF"
                    android:textSize="16sp"
                    android:textStyle="bold" />

            </LinearLayout>

            <!-- RESPIRO ACIMA DO MENU -->
            <Space
                android:layout_width="match_parent"
                android:layout_height="54dp" />

        </LinearLayout>

        <!-- MENU INFERIOR -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/bg_gradient"
            app:itemIconTint="@color/nav_item_color"
            app:itemTextColor="@color/nav_item_color"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu" />

    </RelativeLayout>

    <!-- SIDEBAR PRONTA -->
    <LinearLayout
        android:id="@+id/sidebarMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu"
            android:textColor="#2B2B2B"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Início"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Meus livros"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Reservas"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Perfil"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>