<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#5566F6"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/tvHora"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:layout_marginTop="24dp"
        android:text="9:41"
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <LinearLayout
        android:id="@+id/layoutStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="24dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <View
            android:layout_width="4dp"
            android:layout_height="10dp"
            android:layout_marginEnd="3dp"
            android:background="#FFFFFF" />

        <View
            android:layout_width="4dp"
            android:layout_height="14dp"
            android:layout_marginEnd="3dp"
            android:background="#FFFFFF" />

        <View
            android:layout_width="4dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:background="#FFFFFF" />

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_marginEnd="8dp"
            android:src="@android:drawable/stat_sys_wifi"
            app:tint="#FFFFFF" />

        <View
            android:layout_width="26dp"
            android:layout_height="14dp"
            android:background="@drawable/bg_bateria" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvOla"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="64dp"
        android:text="Olá"
        android:textColor="#AEB6FF"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.498"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvHora" />

    <TextView
        android:id="@+id/tvBemVindo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="Bem-Vindo"
        android:textColor="#FFFFFF"
        android:textSize="34sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOla" />

    <TextView
        android:id="@+id/btnLoginFake"
        android:layout_width="0dp"
        android:layout_height="64dp"
        android:layout_marginStart="40dp"
        android:layout_marginTop="28dp"
        android:layout_marginEnd="40dp"
        android:background="@drawable/bg_login_topo"
        android:gravity="center"
        android:text="Login"
        android:textColor="#11142B"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvBemVindo" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardFormulario"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="24dp"
        android:layout_marginTop="36dp"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_formulario_topo_arredondado"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/btnLoginFake"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTituloForm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Faça seu Login"
            android:textColor="#10132B"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSubtitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Adicione seus dados para entrar"
            android:textColor="#A3A7B7"
            android:textSize="16sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvTituloForm" />

        <TextView
            android:id="@+id/tvMatricula"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="44dp"
            android:text="Matrícula"
            android:textColor="#10132B"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSubtitulo" />

        <EditText
            android:id="@+id/etMatricula"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input"
            android:gravity="center_vertical"
            android:hint="Sua matrícula"
            android:paddingStart="22dp"
            android:paddingEnd="22dp"
            android:textColor="#10132B"
            android:textColorHint="#A3A7B7"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/tvMatricula"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:text="Senha"
            android:textColor="#10132B"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/etMatricula"
            app:layout_constraintStart_toStartOf="parent" />

        <FrameLayout
            android:id="@+id/layoutSenha"
            android:layout_width="0dp"
            android:layout_height="58dp"
            android:layout_marginTop="14dp"
            android:background="@drawable/bg_input"
            app:layout_constraintTop_toBottomOf="@id/tvSenha"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <EditText
                android:id="@+id/etSenha"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@android:color/transparent"
                android:gravity="center_vertical"
                android:hint="Sua senha"
                android:inputType="textPassword"
                android:paddingStart="22dp"
                android:paddingEnd="56dp"
                android:textColor="#10132B"
                android:textColorHint="#A3A7B7"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/ivOlho"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="end|center_vertical"
                android:layout_marginEnd="20dp"
                android:src="@android:drawable/ic_menu_view"
                app:tint="#A3A7B7" />
        </FrameLayout>

        <TextView
            android:id="@+id/tvEsqueceuSenha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:clickable="true"
            android:focusable="true"
            android:text="Esqueceu a senha?"
            android:textColor="#2741A8"
            android:textSize="14sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/layoutSenha" />

        <TextView
            android:id="@+id/btnEntrar"
            android:layout_width="0dp"
            android:layout_height="66dp"
            android:layout_marginStart="14dp"
            android:layout_marginTop="110dp"
            android:layout_marginEnd="14dp"
            android:background="@drawable/bg_botao_entrar"
            android:gravity="center"
            android:text="Entrar"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvEsqueceuSenha" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>