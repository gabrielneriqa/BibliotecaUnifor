<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F4F6">

    <ScrollView
        android:id="@+id/scrollEditarConta"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomNav"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="18dp"
            android:paddingTop="46dp"
            android:paddingEnd="18dp"
            android:paddingBottom="28dp">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardFotoPerfil"
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:layout_gravity="center_horizontal"
                app:cardBackgroundColor="#D9D9D9"
                app:cardCornerRadius="48dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/ivFotoPerfil"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:contentDescription="Foto do perfil"
                    android:scaleType="centerCrop"
                    tools:src="@drawable/img_avatar_1" />
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:id="@+id/tvNomeUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/poppins_bold"
                android:text=""
                android:textColor="#1F1F2E"
                android:textSize="18sp"
                tools:text="Jorge Morais" />

            <TextView
                android:id="@+id/tvEmailUsuario"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="2dp"
                android:fontFamily="@font/poppins_regular"
                android:text=""
                android:textColor="#8B8FA8"
                android:textSize="12sp"
                tools:text="jorgemorais@edu.unifor.com" />

            <TextView
                android:id="@+id/btnEditar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="14dp"
                android:fontFamily="@font/poppins_bold"
                android:text="Editar"
                android:textColor="#1F1F2E"
                android:textSize="13sp" />

            <LinearLayout
                android:id="@+id/formContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="22dp"
                android:orientation="vertical">

                <EditText
                    android:id="@+id/etPrimeiroNome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/poppins_regular"
                    android:hint="Nome"
                    android:inputType="textPersonName"
                    android:paddingTop="10dp"
                    android:paddingBottom="10dp"
                    android:text=""
                    android:textColor="#1F1F2E"
                    android:textColorHint="#8B8FA8"
                    android:textSize="13sp"
                    tools:text="Jorge" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DADBE5" />

                <EditText
                    android:id="@+id/etSobrenome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/poppins_regular"
                    android:hint="Sobrenome"
                    android:inputType="textPersonName"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp"
                    android:text=""
                    android:textColor="#1F1F2E"
                    android:textColorHint="#8B8FA8"
                    android:textSize="13sp"
                    tools:text="Morais" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DADBE5" />

                <LinearLayout
                    android:id="@+id/layoutTelefone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp">

                    <ImageView
                        android:id="@+id/ivBandeiraPais"
                        android:layout_width="24dp"
                        android:layout_height="16dp"
                        android:contentDescription="Bandeira do país"
                        android:scaleType="centerCrop"
                        tools:src="@drawable/flag_brasil" />

                    <EditText
                        android:id="@+id/etTelefone"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:background="@android:color/transparent"
                        android:fontFamily="@font/poppins_regular"
                        android:hint="Telefone"
                        android:inputType="phone"
                        android:padding="0dp"
                        android:text=""
                        android:textColor="#1F1F2E"
                        android:textColorHint="#8B8FA8"
                        android:textSize="13sp"
                        tools:text="(85) 986190520" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DADBE5" />

                <RelativeLayout
                    android:id="@+id/layoutGenero"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp">

                    <TextView
                        android:id="@+id/tvGenero"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_regular"
                        android:text=""
                        android:textColor="#1F1F2E"
                        android:textSize="13sp"
                        tools:text="Gênero" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivSetaGenero"
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:layout_alignParentEnd="true"
                        android:contentDescription="Selecionar gênero"
                        app:srcCompat="@android:drawable/arrow_down_float"
                        app:tint="#8B8FA8" />
                </RelativeLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DADBE5" />

                <EditText
                    android:id="@+id/etDataNascimento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:fontFamily="@font/poppins_regular"
                    android:hint="Data de nascimento"
                    android:inputType="date"
                    android:paddingTop="14dp"
                    android:paddingBottom="10dp"
                    android:text=""
                    android:textColor="#1F1F2E"
                    android:textColorHint="#8B8FA8"
                    android:textSize="13sp"
                    tools:text="10/01/1992" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#DADBE5" />
            </LinearLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnAtualizar"
                android:layout_width="160dp"
                android:layout_height="44dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="28dp"
                app:cardBackgroundColor="#5966FF"
                app:cardCornerRadius="10dp"
                app:cardElevation="0dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/poppins_regular"
                    android:gravity="center"
                    android:text="ATUALIZAR"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp" />
            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="0dp"
        android:layout_height="68dp"
        android:background="#5966FF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:weightSum="4"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Notificações"
                android:src="@android:drawable/ic_menu_view"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical"
            android:background="#80FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Notificações"
                android:src="@android:drawable/ic_popup_reminder"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical"
            android:background="#80FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Calendário"
                android:src="@android:drawable/ic_menu_my_calendar"
                app:tint="#FFFFFF" />
        </LinearLayout>

        <View
            android:layout_width="1dp"
            android:layout_height="60dp"
            android:layout_gravity="center_vertical"
            android:background="#80FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="Perfil"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#FFFFFF" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>