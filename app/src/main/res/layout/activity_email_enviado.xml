<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mainEmailEnviado"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F7F7"
    tools:context=".EmailEnviadoActivity">

    <ImageView
        android:id="@+id/ivVoltar"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:layout_marginStart="24dp"
        android:contentDescription="Voltar"
        android:src="@android:drawable/ic_media_previous"
        app:layout_constraintStart_toStartOf="parent"
        app:tint="#000000"
        tools:layout_editor_absoluteY="84dp" />

    <TextView
        android:id="@+id/tvTituloTopo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="16dp"
        android:text="Esqueci a senha"
        android:textColor="#0F1230"
        android:textSize="28sp"
        app:layout_constraintBottom_toBottomOf="@id/ivVoltar"
        app:layout_constraintStart_toEndOf="@id/ivVoltar"
        app:layout_constraintTop_toTopOf="@id/ivVoltar" />

    <TextView
        android:id="@+id/tvTitulo"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="48dp"
        android:layout_marginTop="140dp"
        android:layout_marginEnd="48dp"
        android:gravity="center"
        android:text="Email enviado com sucesso!"
        android:textColor="#121533"
        android:textSize="30sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivVoltar" />

    <TextView
        android:id="@+id/tvDescricao"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="44dp"
        android:layout_marginTop="26dp"
        android:layout_marginEnd="44dp"
        android:gravity="center"
        android:lineSpacingExtra="4dp"
        android:text="Enviamos um link de redefinição de senha para o seu e-mail."
        android:textColor="#8D90AA"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvTitulo" />

    <ImageView
        android:id="@+id/ivEmailGrande"
        android:layout_width="140dp"
        android:layout_height="140dp"
        android:layout_marginTop="24dp"
        android:contentDescription="Ícone de email"
        android:src="@drawable/ic_email_sucesso"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.483"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvDescricao" />

    <TextView
        android:id="@+id/btnAbrirEmail"
        android:layout_width="0dp"
        android:layout_height="76dp"
        android:layout_marginStart="52dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="52dp"
        android:background="@drawable/bg_botao_redefinir"
        android:gravity="center"
        android:letterSpacing="0.08"
        android:text="ABRIR EMAIL        →"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ivEmailGrande" />

</androidx.constraintlayout.widget.ConstraintLayout>