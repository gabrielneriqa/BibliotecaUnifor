<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <!-- STATUS BAR VISUAL -->
    <RelativeLayout
        android:id="@+id/statusBarFake"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:background="#FFFFFF"
        android:paddingStart="24dp"
        android:paddingEnd="18dp">

        <TextView
            android:id="@+id/tvHora"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="9:41"
            android:textColor="#000000"
            android:textSize="12sp"
            android:textStyle="bold" />

        <LinearLayout
            android:id="@+id/statusIcons"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:gravity="center"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="12dp"
                android:contentDescription="Sinal"
                android:src="@drawable/ic_status_signal" />

            <ImageView
                android:layout_width="15dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:contentDescription="Wi-Fi"
                android:src="@drawable/ic_status_wifi" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="12dp"
                android:layout_marginStart="4dp"
                android:contentDescription="Bateria"
                android:src="@drawable/ic_status_battery" />

        </LinearLayout>

    </RelativeLayout>

    <!-- TOPO -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_below="@id/statusBarFake"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="18dp"
        android:paddingEnd="18dp">

        <ImageView
            android:id="@+id/btnVoltar"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:contentDescription="Voltar"
            android:src="@drawable/ic_arrow_back"
            android:tint="#111827" />

        <TextView
            android:id="@+id/tvTituloTela"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:text="Esqueci a senha"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- CONTEÚDO CENTRAL -->
    <LinearLayout
        android:id="@+id/contentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_marginTop="58dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="32dp"
        android:paddingEnd="32dp">

        <TextView
            android:id="@+id/tvSucesso"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Email enviado com\nsucesso!"
            android:textColor="#111827"
            android:textSize="18sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvDescricao"
            android:layout_width="280dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:lineSpacingExtra="4dp"
            android:text="Enviamos um link de redefinição de senha para o seu e-mail."
            android:textColor="#8A94A6"
            android:textSize="13sp" />

        <!-- CARD DO ÍCONE -->
        <FrameLayout
            android:id="@+id/cardIconeEmail"
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:layout_marginTop="46dp"
            android:background="@drawable/bg_email_icon_container">

            <ImageView
                android:id="@+id/imgEmail"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_gravity="center"
                android:contentDescription="Email enviado"
                android:src="@drawable/ic_email_sucesso"
                android:tint="#7A7A7A" />

        </FrameLayout>

        <!-- BOTÃO -->
        <TextView
            android:id="@+id/btnAbrirEmail"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="58dp"
            android:background="@drawable/bg_button_primary"
            android:elevation="8dp"
            android:gravity="center"
            android:letterSpacing="0.08"
            android:text="ABRIR EMAIL     →"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />

    </LinearLayout>

</RelativeLayout>