<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <!-- CONTEÚDO PRINCIPAL -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF">

        <!-- HEADER AZUL -->
        <LinearLayout
            android:id="@+id/header"
            android:layout_width="match_parent"
            android:layout_height="158dp"
            android:background="@drawable/bg_header"
            android:orientation="vertical"
            android:paddingStart="22dp"
            android:paddingTop="16dp"
            android:paddingEnd="22dp">

            <!-- TOPO DO HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="52dp">

                <TextView
                    android:id="@+id/tvHora"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_marginStart="10dp"
                    android:layout_marginTop="2dp"
                    android:text="9:41"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/statusIcons"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="4dp"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="12dp"
                        android:contentDescription="Sinal"
                        android:src="@drawable/ic_status_signal"
                        android:tint="#FFFFFF" />

                    <ImageView
                        android:layout_width="15dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="Wi-Fi"
                        android:src="@drawable/ic_status_wifi"
                        android:tint="#FFFFFF" />

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="12dp"
                        android:layout_marginStart="4dp"
                        android:contentDescription="Bateria"
                        android:src="@drawable/ic_status_battery"
                        android:tint="#FFFFFF" />

                </LinearLayout>

                <ImageButton
                    android:id="@+id/btnMenu"
                    android:layout_width="42dp"
                    android:layout_height="42dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentBottom="true"
                    android:background="@android:color/transparent"
                    android:contentDescription="Menu"
                    android:padding="8dp"
                    android:src="@drawable/ic_menu"
                    android:tint="#FFFFFF" />

                <LinearLayout
                    android:id="@+id/locationContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:layout_alignParentBottom="true"
                    android:gravity="center_horizontal"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sua Localização ▾"
                        android:textAlignment="center"
                        android:textColor="#DDE2FF"
                        android:textSize="12sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Fortaleza"
                        android:textAlignment="center"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </RelativeLayout>

            <!-- SEARCH + FILTRO -->
            <LinearLayout
                android:id="@+id/searchFilterContainer"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="22dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- BUSCA -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="50dp"
                    android:layout_weight="1"
                    android:background="@android:color/transparent"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:contentDescription="Pesquisar"
                        android:src="@drawable/ic_search"
                        android:tint="#FFFFFF" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="28dp"
                        android:layout_marginStart="14dp"
                        android:layout_marginEnd="10dp"
                        android:background="#80FFFFFF" />

                    <EditText
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@null"
                        android:hint="Buscas livros"
                        android:inputType="text"
                        android:padding="0dp"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#C9D0FF"
                        android:textSize="20sp" />

                </LinearLayout>

                <!-- BOTÃO FILTROS -->
                <LinearLayout
                    android:layout_width="86dp"
                    android:layout_height="40dp"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_filter_button"
                    android:gravity="center"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="22dp"
                        android:layout_height="22dp"
                        android:contentDescription="Filtros"
                        android:src="@drawable/ic_filter"
                        android:tint="#5966FF" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="6dp"
                        android:text="Filtros"
                        android:textColor="#FFFFFF"
                        android:textSize="13sp" />

                </LinearLayout>

            </LinearLayout>

        </LinearLayout>

        <!-- CONTEÚDO ROLÁVEL -->
        <ScrollView
            android:id="@+id/scrollContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/header"
            android:layout_above="@id/bottomNav"
            android:fillViewport="true"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="34dp"
                android:paddingTop="12dp"
                android:paddingEnd="24dp"
                android:paddingBottom="24dp">

                <!-- VOLTAR -->
                <LinearLayout
                    android:id="@+id/backContainer"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="14dp"
                        android:layout_height="14dp"
                        android:contentDescription="Voltar"
                        android:src="@drawable/ic_back"
                        android:tint="#A6A6A6" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2dp"
                        android:text="Voltar"
                        android:textColor="#8C8C8C"
                        android:textSize="14sp" />

                </LinearLayout>

                <!-- TÍTULO -->
                <TextView
                    android:id="@+id/tvTituloBiblioteca"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Biblioteca Unifor"
                    android:textColor="#2B2B2B"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- CATEGORIAS -->
                <HorizontalScrollView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:scrollbars="none">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="142dp"
                            android:layout_height="42dp"
                            android:background="@drawable/bg_category_chip"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:gravity="center"
                                android:text="☕"
                                android:textColor="#000000"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Fantasia"
                                android:textColor="#3F3F46"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="142dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_category_chip"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:gravity="center"
                                android:text="🎓"
                                android:textColor="#000000"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Ciência"
                                android:textColor="#3F3F46"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="142dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="6dp"
                            android:background="@drawable/bg_category_chip"
                            android:gravity="center"
                            android:orientation="horizontal"
                            android:paddingStart="12dp"
                            android:paddingEnd="12dp">

                            <TextView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:gravity="center"
                                android:text="💖"
                                android:textColor="#000000"
                                android:textSize="18sp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="12dp"
                                android:text="Romance"
                                android:textColor="#3F3F46"
                                android:textSize="15sp"
                                android:textStyle="bold" />

                        </LinearLayout>

                    </LinearLayout>

                </HorizontalScrollView>

                <!-- LISTA DE LIVROS -->
                <LinearLayout
                    android:id="@+id/listaLivros"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="18dp"
                    android:orientation="vertical">

                    <!-- ITEM 1 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="92dp"
                            android:layout_height="125dp"
                            android:contentDescription="Capa do livro"
                            android:scaleType="centerCrop"
                            android:src="@drawable/Storytelling"
                            app:shapeAppearanceOverlay="@style/RoundedBookCover" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Storytelling com Dados"
                                android:textColor="#2B2020"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Ano: 2019"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Autor: Cole\nNussbaumer Knaflic"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Código: 456566"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="38dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_detail_button"
                                android:gravity="center"
                                android:text="Ver detalhes"
                                android:textColor="#FF6B6B"
                                android:textSize="13sp" />

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="32dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_available_button"
                                android:gravity="center"
                                android:text="Disponível"
                                android:textColor="#28D888"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- ITEM 2 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="92dp"
                            android:layout_height="125dp"
                            android:contentDescription="Capa do livro"
                            android:scaleType="centerCrop"
                            android:src="@drawable/sql"
                            app:shapeAppearanceOverlay="@style/RoundedBookCover" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Introdução à Linguagem SQL"
                                android:textColor="#2B2020"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Ano: 2019"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Autor: Thomas Nield"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Código: 456566"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="38dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_detail_button"
                                android:gravity="center"
                                android:text="Ver detalhes"
                                android:textColor="#FF6B6B"
                                android:textSize="13sp" />

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="32dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_unavailable_button"
                                android:gravity="center"
                                android:text="indisponível"
                                android:textColor="#FF6B6B"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- ITEM 3 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="92dp"
                            android:layout_height="125dp"
                            android:contentDescription="Capa do livro"
                            android:scaleType="centerCrop"
                            android:src="@drawable/mysql"
                            app:shapeAppearanceOverlay="@style/RoundedBookCover" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Aprendendo Banco de Dados MYSQL"
                                android:textColor="#2B2020"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Ano: 2019"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Autor: Cole Nussbaumer\nKnaflic"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Código: 456566"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="38dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_detail_button"
                                android:gravity="center"
                                android:text="Ver detalhes"
                                android:textColor="#FF6B6B"
                                android:textSize="13sp" />

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="32dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_available_button"
                                android:gravity="center"
                                android:text="Disponível"
                                android:textColor="#28D888"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                    <!-- ITEM 4 -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:orientation="horizontal">

                        <com.google.android.material.imageview.ShapeableImageView
                            android:layout_width="92dp"
                            android:layout_height="125dp"
                            android:contentDescription="Capa do livro"
                            android:scaleType="centerCrop"
                            android:src="@drawable/storytelling"
                            app:shapeAppearanceOverlay="@style/RoundedBookCover" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="18dp"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Storytelling com Dados"
                                android:textColor="#2B2020"
                                android:textSize="17sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="12dp"
                                android:text="Ano: 2019"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Autor: Cole Nussbaumer"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Código: 456566"
                                android:textColor="#8A8A8A"
                                android:textSize="14sp" />

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="96dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="38dp"
                            android:gravity="center"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="32dp"
                                android:background="@drawable/bg_detail_button"
                                android:gravity="center"
                                android:text="Ver detalhes"
                                android:textColor="#FF6B6B"
                                android:textSize="13sp" />

                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="32dp"
                                android:layout_marginTop="8dp"
                                android:background="@drawable/bg_available_button"
                                android:gravity="center"
                                android:text="Disponível"
                                android:textColor="#28D888"
                                android:textSize="13sp" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <!-- BOTTOM NAV -->
        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottomNav"
            android:layout_width="match_parent"
            android:layout_height="76dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/bg_gradient"
            app:itemIconTint="@color/nav_item_color"
            app:itemTextColor="@color/nav_item_color"
            app:labelVisibilityMode="unlabeled"
            app:menu="@menu/bottom_nav_menu" />

    </RelativeLayout>

    <!-- SIDEBAR PRONTA (VISUAL) -->
    <LinearLayout
        android:id="@+id/sidebarMenu"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Menu"
            android:textColor="#2B2B2B"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Início"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Meus livros"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Reservas"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:text="Perfil"
            android:textColor="#4A4A4A"
            android:textSize="16sp" />

    </LinearLayout>

</androidx.drawerlayout.widget.DrawerLayout>